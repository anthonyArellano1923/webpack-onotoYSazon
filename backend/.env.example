PORT=4000
NODE_ENV=development

# Ruta del archivo SQLite.
# En producción (Render): /data/onoto.db  (disco persistente montado en /data)
# En desarrollo: dejar vacío para usar backend/onoto.db por defecto
DB_PATH=

# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza-esto-con-una-clave-secreta-de-64-bytes

# Duración del token: 2h, 1d, 7d, etc.
JWT_EXPIRES_IN=2h

# Solo permite peticiones desde este origen (cambia en producción)
CORS_ORIGIN=http://localhost:3006

# Cuenta de administrador (se crea automáticamente al iniciar)
ADMIN_EMAIL=admin@onotosazon.cl
# Si la contraseña contiene '#', ponla entre comillas: ADMIN_PASSWORD="Mi#Clave123"
ADMIN_PASSWORD=CambiaMeEnProduccion123!
ADMIN_NAME=Admin
